# =========================================================================
# Variables d'environnement — CdC §0. Copier vers .env et renseigner.
# Préfixe PUBLIC_ = exposé au client (Astro). Sans préfixe = secret serveur.
# AUCUN secret ne doit être commité.
# =========================================================================

# --- Identité / SEO ---
PUBLIC_SITE_NAME="MASPIE-BI"
PUBLIC_SITE_URL="https://expert-data-powerbi.fr"
PUBLIC_CONTACT_EMAIL="pierre.masson@maspie.com"
PUBLIC_CITY=""
PUBLIC_VOICE="nous"             # "je" ou "nous" (§17.3)

# --- Conversion (§10) ---
PUBLIC_CTA_LABEL="Réserver un diagnostic"
PUBLIC_RDV_URL=""               # Agenda Calendly / cal.com (§0 {{RDV_URL}})
WEBHOOK_N8N=""                  # Webhook formulaire (§0 {{WEBHOOK_N8N}}) — SECRET
PUBLIC_TURNSTILE_SITE_KEY=""    # Cloudflare Turnstile (clé publique)
TURNSTILE_SECRET_KEY=""         # Cloudflare Turnstile — SECRET

# --- Analytics cookieless (§12) ---
PUBLIC_PLAUSIBLE_DOMAIN=""

# --- Références (§11) — wording validé uniquement ---
PUBLIC_REFERENCES_TITLE="Ils m’ont fait confiance"

# --- TinaCMS (CMS git-based, /admin) ---
TINA_BRANCH="main"
TINA_CLIENT_ID=""               # Tina Cloud (gratuit) — SECRET
TINA_TOKEN=""                   # Tina Cloud — SECRET
