---
/** En-tête : logo + navigation (§7) + CTA primaire unique. */
import Container from '../ui/Container.astro';
import Button from '../ui/Button.astro';
import { site, cta } from '../../config/site';

const nav = [
  { label: 'Offres', href: '/offres/' },
  { label: 'Comment ça marche', href: '/comment-ca-marche/' },
  { label: 'Contact', href: '/contact/' },
];
const path = Astro.url.pathname;
const isActive = (href: string) => path === href || path.startsWith(href);
---
<header class="sticky top-0 z-40 border-b border-line/70 bg-white/85 backdrop-blur">
  <Container size="wide" class="flex h-16 items-center justify-between gap-4">
    <a href="/" class="flex items-center gap-2.5 font-display text-lg font-bold text-ink">
      <span class="grid h-8 w-8 place-items-center rounded-lg bg-gradient-to-br from-brand-500 to-azur-600 text-white">
        <svg width="18" height="18" viewBox="0 0 24 24" aria-hidden="true" fill="currentColor">
          <rect x="4" y="12" width="3.5" height="8" rx="1.5" />
          <rect x="10.25" y="7" width="3.5" height="13" rx="1.5" />
          <rect x="16.5" y="10" width="3.5" height="10" rx="1.5" opacity="0.7" />
        </svg>
      </span>
      <span>{site.name}</span>
    </a>

    <nav aria-label="Navigation principale" class="hidden items-center gap-7 md:flex">
      {nav.map((item) => (
        <a
          href={item.href}
          aria-current={isActive(item.href) ? 'page' : undefined}
          class:list={[
            'text-sm font-medium transition-colors hover:text-brand-700',
            isActive(item.href) ? 'text-brand-700' : 'text-ink-soft',
          ]}
        >
          {item.label}
        </a>
      ))}
      <Button href={cta.href} size="md" data-event="cta_header">{cta.label}</Button>
    </nav>

    <!-- Mobile : menu déroulant natif (zéro JS de framework) -->
    <details class="relative md:hidden">
      <summary
        class="grid h-10 w-10 cursor-pointer list-none place-items-center rounded-lg ring-1 ring-line"
        aria-label="Ouvrir le menu"
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path d="M4 7h16M4 12h16M4 17h16" stroke-linecap="round" />
        </svg>
      </summary>
      <div class="absolute right-0 mt-2 w-60 rounded-xl border border-line bg-white p-3 shadow-card-lg">
        <nav aria-label="Navigation mobile" class="flex flex-col gap-1">
          {nav.map((item) => (
            <a href={item.href} class="rounded-lg px-3 py-2 text-sm font-medium text-ink-soft hover:bg-surface-soft hover:text-ink">
              {item.label}
            </a>
          ))}
          <Button href={cta.href} class="mt-2 w-full" data-event="cta_header_mobile">{cta.label}</Button>
        </nav>
      </div>
    </details>
  </Container>
</header>
