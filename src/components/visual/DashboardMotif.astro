---
/**
 * Motif « tableau de bord » abstrait et ORIGINAL (§8B).
 * Décoratif uniquement (aria-hidden). N'imite aucune capture Power BI.
 */
interface Props {
  class?: string;
}
const { class: className = '' } = Astro.props;
---
<svg
  class={className}
  viewBox="0 0 480 320"
  fill="none"
  xmlns="http://www.w3.org/2000/svg"
  aria-hidden="true"
  role="presentation"
>
  <defs>
    <linearGradient id="motif-brand" x1="0" y1="0" x2="1" y2="1">
      <stop offset="0" stop-color="#0EA5A4" />
      <stop offset="0.6" stop-color="#2563EB" />
      <stop offset="1" stop-color="#7C3AED" />
    </linearGradient>
    <linearGradient id="motif-fade" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0" stop-color="#2563EB" stop-opacity="0.18" />
      <stop offset="1" stop-color="#2563EB" stop-opacity="0" />
    </linearGradient>
  </defs>

  <!-- carte de fond -->
  <rect x="0.5" y="0.5" width="479" height="319" rx="20" fill="#ffffff" />
  <rect x="0.5" y="0.5" width="479" height="319" rx="20" stroke="#e2e8f0" />

  <!-- KPI en haut -->
  <rect x="28" y="28" width="120" height="14" rx="7" fill="#e2e8f0" />
  <rect x="28" y="52" width="72" height="22" rx="6" fill="url(#motif-brand)" />
  <rect x="320" y="28" width="132" height="56" rx="12" fill="#f8fafc" stroke="#e2e8f0" />
  <circle cx="346" cy="56" r="12" fill="#0EA5A4" opacity="0.18" />
  <circle cx="346" cy="56" r="5" fill="#0EA5A4" />
  <rect x="368" y="44" width="64" height="9" rx="4.5" fill="#cbd5e1" />
  <rect x="368" y="62" width="44" height="9" rx="4.5" fill="#e2e8f0" />

  <!-- aire + courbe (data line en mouvement côté CSS) -->
  <path
    d="M28 230 L92 196 L156 210 L220 150 L284 168 L348 110 L452 132 L452 268 L28 268 Z"
    fill="url(#motif-fade)"
  />
  <path
    class="motif-line"
    d="M28 230 L92 196 L156 210 L220 150 L284 168 L348 110 L452 132"
    stroke="url(#motif-brand)"
    stroke-width="3"
    stroke-linecap="round"
    stroke-linejoin="round"
  />
  <circle cx="220" cy="150" r="4.5" fill="#2563EB" />
  <circle cx="348" cy="110" r="4.5" fill="#F59E0B" />

  <!-- barres -->
  <g class="motif-bars">
    <rect x="28" y="272" width="22" height="20" rx="4" fill="#0EA5A4" opacity="0.85" />
    <rect x="62" y="258" width="22" height="34" rx="4" fill="#2563EB" opacity="0.8" />
    <rect x="96" y="266" width="22" height="26" rx="4" fill="#2563EB" opacity="0.55" />
    <rect x="130" y="250" width="22" height="42" rx="4" fill="#F59E0B" opacity="0.9" />
  </g>
</svg>
