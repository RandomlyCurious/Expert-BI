---
/**
 * Bloc d'offre — pilier (§6).
 * RÈGLES NON NÉGOCIABLES appliquées ici :
 *  - PAS de tableau 3 colonnes : chaque pilier est un bloc distinct.
 *  - « C'est pour vous si… » obligatoire (sélection par situation, pas par prix).
 *  - `dominant` = Pilier 1 (poids visuel supérieur, plus détaillé).
 *  - Aucun nombre de jours/mois ; pas de prix sur Dev (au-delà du « à partir de »)
 *    ni sur l'automatisation (gérer en amont via la config).
 */
interface Props {
  rank?: string;            // ex. "01"
  dominant?: boolean;
  title: string;
  tagline?: string;
  forWho: string;           // texte du « C'est pour vous si… »
  benefits: string[];
  price?: string;           // libellé prix déjà formaté (centralisé)
  priceNote?: string;
  packs?: { hours: number; price: string }[]; // packs internes d'UN pilier (Assistance)
  href: string;
  ctaLabel?: string;
}
const {
  rank,
  dominant = false,
  title,
  tagline,
  forWho,
  benefits,
  price,
  priceNote,
  packs,
  href,
  ctaLabel = 'En savoir plus',
} = Astro.props;

---
<article
  data-reveal
  class:list={[
    'group relative flex flex-col rounded-card bg-white transition-shadow',
    dominant
      ? 'p-7 shadow-card-lg ring-1 ring-brand-100 sm:p-9 lg:flex-row lg:gap-10'
      : 'p-6 shadow-card ring-1 ring-line hover:shadow-card-lg',
  ]}
>
  {dominant && (
    <span class="pointer-events-none absolute inset-x-0 top-0 h-1 rounded-t-card bg-gradient-to-r from-brand-500 via-azur-600 to-violet-500"></span>
  )}

  <div class:list={['flex flex-col', dominant && 'lg:w-3/5']}>
    <div class="flex items-center gap-3">
      {rank && (
        <span class:list={[
          'font-display text-sm font-bold tabular-nums',
          dominant ? 'text-brand-600' : 'text-muted',
        ]}>{rank}</span>
      )}
      {dominant && (
        <span class="rounded-full bg-brand-50 px-2.5 py-0.5 text-xs font-semibold tracking-wide text-brand-700 uppercase">
          Offre phare
        </span>
      )}
    </div>

    <h3 class:list={['mt-2 font-display font-bold text-ink', dominant ? 'text-2xl sm:text-3xl' : 'text-xl']}>{title}</h3>
    {tagline && <p class="mt-2 text-ink-soft">{tagline}</p>}

    <!-- « C'est pour vous si… » (§6.2) -->
    <div class:list={[
      'mt-5 rounded-xl border-l-4 p-4',
      dominant ? 'border-brand-500 bg-brand-50/60' : 'border-line bg-surface-soft',
    ]}>
      <p class="text-sm font-semibold text-ink">C'est pour vous si…</p>
      <p class="mt-1 text-sm text-ink-soft">{forWho}</p>
    </div>
  </div>

  <div class:list={['mt-6 flex flex-col', dominant && 'lg:mt-0 lg:w-2/5 lg:border-l lg:border-line lg:pl-10']}>
    <ul class="space-y-2.5">
      {benefits.map((b) => (
        <li class="flex gap-2.5 text-sm text-ink-soft">
          <svg class="mt-0.5 h-4 w-4 flex-none text-brand-500" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
            <path fill-rule="evenodd" d="M16.7 5.3a1 1 0 0 1 0 1.4l-7.5 7.5a1 1 0 0 1-1.4 0L3.3 9.7a1 1 0 1 1 1.4-1.4l3.1 3.1 6.8-6.8a1 1 0 0 1 1.4 0Z" clip-rule="evenodd" />
          </svg>
          <span>{b}</span>
        </li>
      ))}
    </ul>

    <div class="mt-auto pt-6">
      {packs && (
        <div class="grid grid-cols-3 gap-2">
          {packs.map((p) => (
            <div class="rounded-lg bg-surface-soft px-2 py-3 text-center">
              <p class="price font-display text-lg font-bold text-ink tabular-nums">{p.price}</p>
              <p class="mt-0.5 text-xs text-muted tabular-nums">{p.hours} h</p>
            </div>
          ))}
        </div>
      )}
      {!packs && price && (
        <p class="price font-display text-2xl font-bold text-ink">
          {price}
          {priceNote && <span class="ml-1 align-middle text-sm font-normal text-muted">{priceNote}</span>}
        </p>
      )}
      <a
        href={href}
        class:list={[
          'mt-4 inline-flex items-center gap-1.5 text-sm font-semibold transition-colors',
          dominant ? 'text-brand-700 hover:text-brand-900' : 'text-azur-600 hover:text-azur-700',
        ]}
      >
        {ctaLabel}
        <svg class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
          <path fill-rule="evenodd" d="M7.3 4.3a1 1 0 0 1 1.4 0l5 5a1 1 0 0 1 0 1.4l-5 5a1 1 0 0 1-1.4-1.4L11.6 10 7.3 5.7a1 1 0 0 1 0-1.4Z" clip-rule="evenodd" />
        </svg>
      </a>
    </div>
  </div>
</article>
